# ── Medinex NLP Layer · Environment Config ──────────────────────────────────
# Copy to .env and fill in your values

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# Redis (Celery broker + result backend)
REDIS_URL=redis://localhost:6379/0

# NLP Model names (scispaCy)
# Primary general biomedical NER model
NLP_MODEL_PRIMARY=en_core_sci_lg
# Chemical + disease specialist
NLP_MODEL_BC5CDR=en_ner_bc5cdr_md
# Cancer genetics specialist
NLP_MODEL_BIONLP=en_ner_bionlp13cg_md

# Entity linking
# UMLS linker (requires UMLS licence data cached by scispaCy)
ENTITY_LINKER=umls
# Minimum confidence score for an entity to be written to Neo4j
ENTITY_LINK_THRESHOLD=0.85

# PubMed (Step 6 - future)
PUBMED_API_KEY=your_pubmed_api_key_here
PUBMED_EMAIL=your_email@example.com

# App
APP_ENV=development
LOG_LEVEL=INFO
