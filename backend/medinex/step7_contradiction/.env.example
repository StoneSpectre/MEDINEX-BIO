# Copy to .env and fill in your real infra. Loaded via python-dotenv if you
# `from dotenv import load_dotenv; load_dotenv()` at the top of an entrypoint,
# or export these directly in your shell/deployment.

# --- Postgres (claim store) ---
POSTGRES_DSN=postgresql://medinex:medinex@localhost:5432/medinex
POSTGRES_POOL_MIN=1
POSTGRES_POOL_MAX=10

# --- Neo4j (claim graph / contradiction graph) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me
NEO4J_DATABASE=neo4j

# --- LLM (claim extraction + hypothesis generation) ---
MEDINEX_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=1024

# --- NLI service ---
NLI_MODEL_NAME=pritamdeka/PubMedBERT-MNLI-MedNLI
NLI_DEVICE=cpu
NLI_BATCH_SIZE=16
NLI_SERVICE_HOST=0.0.0.0
NLI_SERVICE_PORT=8081
